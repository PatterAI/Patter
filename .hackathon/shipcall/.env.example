# Patter / Twilio — required for outbound calls
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15550001234

# OpenAI — required for Realtime voice AI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook — ngrok public hostname (NO scheme, e.g. abc.ngrok.io)
WEBHOOK_URL=abc.ngrok.io

# Developer phone number to call (E.164 format)
DEV_PHONE_NUMBER=+15559876543

# Server port
PORT=8080
