# VoiceScope Environment Variables
# Copy to .env and fill in your values.

# Google AI Studio — Gemini 3 vision API
# Get from: https://aistudio.google.com/apikey
GOOGLE_AI_STUDIO_KEY=your_google_ai_studio_key

# OpenAI — Realtime API for voice (Patter voice provider)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio — phone number and credentials for outbound calls
# Get from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15550001234

# Webhook URL — public hostname where Twilio can reach this server
# If using ngrok: run `ngrok http 8000` and paste the hostname (no https://)
# If deployed to Cloud Run: use the Cloud Run URL hostname
WEBHOOK_URL=abc.ngrok-free.app
