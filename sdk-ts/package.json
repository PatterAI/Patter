{
  "name": "getpatter",
  "version": "0.4.0",
  "description": "Connect AI agents to phone numbers in 4 lines of code",
  "license": "MIT",
  "author": {
    "name": "PatterAI",
    "email": "hello@getpatter.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PatterAI/Patter.git",
    "directory": "sdk-ts"
  },
  "homepage": "https://www.getpatter.com",
  "bugs": {
    "url": "https://github.com/PatterAI/Patter/issues"
  },
  "keywords": [
    "voice",
    "ai",
    "phone",
    "telephony",
    "speech",
    "tts",
    "stt",
    "twilio",
    "telnyx",
    "openai",
    "elevenlabs"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "getpatter": "dist/cli.js"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts && tsup src/cli.ts --format cjs --no-dts",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^5.2.1",
    "ws": "^8.18.0"
  },
  "optionalDependencies": {
    "cloudflared": "^1.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/express": "^5.0.6",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^3.2.4",
    "playwright": "^1.59.1",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
