# === Database (Supabase PostgreSQL) ===
PATTER_DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# === Security ===
PATTER_ENCRYPTION_KEY=generate-a-random-32-char-string-here
PATTER_ENV=development

# === Backend ===
PATTER_BASE_URL=localhost:8000
PATTER_REDIS_URL=redis://localhost:6379/0

# === Webhook Validation (optional) ===
PATTER_WEBHOOK_VALIDATION_ENABLED=false
PATTER_WEBHOOK_SECRET=

# === External Provider Keys (set these when testing calls) ===
# Telnyx
TELNYX_API_KEY=
# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Deepgram (STT)
DEEPGRAM_API_KEY=
# ElevenLabs (TTS)
ELEVENLABS_API_KEY=
# OpenAI (Whisper STT / TTS)
OPENAI_API_KEY=
